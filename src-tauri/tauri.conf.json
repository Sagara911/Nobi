{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nobi",
  "version": "0.1.0",
  "identifier": "com.nobi.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nobi",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBQkQ5MTcyRUUzMDE2NzIKUldSeUZqRHVjcEc5aWlaM3ZiVjlvQ3JsUUxJK2NkZ0t1MXlCUW16OEJzVlp4NC94OCt3NGJBQm8K",
      "endpoints": [
        "https://github.com/Sagara911/Nobi/releases/latest/download/latest.json"
      ]
    }
  }
}
